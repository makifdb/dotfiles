[user]
	name = Mehmet Akif Duba
	email = mail@makifdb.com

[color]
	ui = auto

[init]
	defaultBranch = main

[core]
	editor = nvim
	excludesfile = ~/.gitignore_global

[filter "lfs"]
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f

[credential]
	helper = cache

[core]
	pager = delta

[interactive]
	diffFilter = delta

[delta]
  	navigate = true
  	light = false
  	side-by-side = false
	line-numbers = true

[merge]
  	conflictstyle = diff3

[diff]
  	colorMoved = default
